{
	"name": "theme",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"gen:og": "node scripts/generate-og.mjs",
		"build": "node scripts/fetch-content.js || echo \"⚠ md generation skipped\" && node scripts/generate-og.mjs || echo \"⚠ OG generation skipped\" && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/noto-sans-sc": "^5.2.10",
		"@resvg/resvg-js": "^2.6.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"mdsvex": "./plugins/md/mdsvex-0.12.9.tgz",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"remark-toc": "^9.0.0",
		"satori": "^0.28.0",
		"sharp": "^0.35.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@speed-highlight/core": "^1.2.17",
		"fuse.js": "^7.5.0",
		"geist": "^1.7.2",
		"mermaid": "^11.16.0",
		"shiki": "^4.3.1",
		"svelte-lucide": "^3.0.1"
	}
}
